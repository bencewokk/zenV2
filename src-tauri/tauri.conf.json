{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zen",
  "version": "3.0.0",
  "identifier": "com.zen.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/sync-version.mjs && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Zen",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bencewokk/zenV2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5NEM1RUUyQTM3MDhCMTYKUldRV2kzQ2o0bDVNV1llVHlVRFNXWUUvUG5yQ2RVb0hFTzlVUjZ2SlZwSitLdllxZmFPaDMvTVAK"
    }
  }
}
